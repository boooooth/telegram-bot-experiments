# Copy to .env and fill in real values. .env is gitignored — never commit secrets.
# Required: Telegram Bot API token from BotFather.
TELEGRAM_BOT_TOKEN=
# Required: API key for whichever LLM provider you use.
#   OpenAI    → key from platform.openai.com
#   Anthropic → key from console.anthropic.com
LLM_API_KEY=
# Optional: model name passed to LiteLLM. Defaults to gpt-4o-mini if unset.
# Examples:
#   gpt-4o-mini                 (OpenAI)
#   gpt-4o                      (OpenAI)
#   claude-haiku-4-5-20251001   (Anthropic)
#   claude-sonnet-4-6           (Anthropic)
LLM_MODEL=
# Optional: model name for image/vision requests. Defaults to gpt-4o-mini if unset.
# Must be a vision-capable model.
LLM_VISION_MODEL=

# Optional: comma-separated Telegram user IDs allowed to use the bot (direct messages and @mentions).
# If unset, everyone is allowed.
ALLOWED_USER_IDS=